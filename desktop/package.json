{
  "name": "morpheus-desktop",
  "version": "1.0.0",
  "description": "Self-hosted AI workspace — desktop app",
  "main": "src/main/index.js",
  "author": {
    "name": "Ghost Network",
    "email": "ghost-network666@users.noreply.github.com",
    "url": "https://github.com/Ghost-Network666"
  },
  "homepage": "https://github.com/Ghost-Network666/Morpheus",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ghost-Network666/Morpheus.git"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron . --dev",
    "start:dev": "electron . --dev",
    "copy-static": "node scripts/copy-static.js",
    "build": "npm run copy-static && electron-builder",
    "pack": "npm run copy-static && electron-builder --dir",
    "dist": "npm run copy-static && electron-builder --publish never",
    "fetch:python:win": "node scripts/fetch-python-runtime.js win-x64",
    "fetch:python:mac:x64": "node scripts/fetch-python-runtime.js mac-x64",
    "fetch:python:mac:arm64": "node scripts/fetch-python-runtime.js mac-arm64",
    "build:win": "npm run fetch:python:win && npm run build -- --win --x64",
    "build:mac:x64": "npm run fetch:python:mac:x64 && npm run build -- --mac --x64",
    "build:mac:arm64": "npm run fetch:python:mac:arm64 && npm run build -- --mac --arm64",
    "icons": "python3 scripts/generate-icon.py",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "ssh2": "1.17.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "fs-extra": "^11.1.1"
  }
}
