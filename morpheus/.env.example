# Morpheus Configuration
# Copy to .env and adjust as needed

# Server
APP_HOST=127.0.0.1
APP_PORT=7860
APP_DEBUG=false

# Auth (disable for local-only, enable for server installs)
AUTH_ENABLED=false
SECRET_KEY=change-me-to-a-random-64-char-string
SESSION_EXPIRE_DAYS=30

# Admin user (created on first run if auth enabled)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Trusted networks (bypass auth from these CIDRs)
TRUSTED_LAN=127.0.0.1/8,::1

# AI Providers
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=

# Default model
DEFAULT_MODEL=llama3.2:3b
DEFAULT_PROVIDER=ollama

# RAG / ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_IN_PROCESS=true

# Search
SEARXNG_URL=http://localhost:8888
BRAVE_API_KEY=
GOOGLE_PSE_KEY=
GOOGLE_PSE_CX=
TAVILY_API_KEY=

# Notifications
NTFY_URL=http://localhost:8080
NTFY_TOPIC=morpheus

# Tailscale
TAILSCALE_DETECT=true

# Encryption key for vault (auto-generated on first run if empty)
VAULT_KEY=

# PostgreSQL (leave blank to use SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/morpheus

# Obsidian vault integration
OBSIDIAN_VAULT_PATH=
MODULE_OBSIDIAN=true

# Agent memory source: local (ChromaDB), obsidian (vault notes), or both
MEMORY_SOURCE=local

# Server discovery
DISCOVERY_MDNS=true
DISCOVERY_TAILSCALE=true

# Update checks
UPDATE_CHECK=true

# Slack webhook (optional notifications)
SLACK_WEBHOOK=

# Linear integration
LINEAR_API_KEY=

# Notion integration
NOTION_TOKEN=

# GitHub integration
GITHUB_TOKEN=

# Feature toggles
MODULE_TERMINAL=true
MODULE_SSH=true
MODULE_AGENT=true
MODULE_RAG=true
MODULE_EMAIL=true
MODULE_CALENDAR=true
MODULE_NOTES=true
MODULE_TASKS=true
MODULE_RESEARCH=true
MODULE_DOCUMENTS=true
MODULE_COOKBOOK=true
MODULE_CONNECTIONS=true
