# Morpheus Configuration
# Copy to .env and adjust as needed

# Server
APP_HOST=127.0.0.1      # Use 0.0.0.0 to expose on the network
APP_PORT=7860
APP_DEBUG=false

# AI Providers
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_BASE_URL=

# Default model
DEFAULT_MODEL=llama3.2:3b
DEFAULT_PROVIDER=ollama

# RAG / ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_IN_PROCESS=true

# Search
SEARXNG_URL=http://localhost:8888
BRAVE_API_KEY=
GOOGLE_PSE_KEY=
GOOGLE_PSE_CX=
TAVILY_API_KEY=

# Notifications
NTFY_URL=http://localhost:8080
NTFY_TOPIC=morpheus

# Integrations
SLACK_WEBHOOK=
LINEAR_API_KEY=
NOTION_TOKEN=
GITHUB_TOKEN=

# Tailscale
TAILSCALE_DETECT=true

# Encryption key for vault (auto-generated on first run if empty)
VAULT_KEY=

# PostgreSQL (leave blank to use SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/morpheus

# Obsidian vault integration
OBSIDIAN_VAULT_PATH=
MODULE_OBSIDIAN=true

# Agent memory source: local (ChromaDB), obsidian (vault notes), or both
MEMORY_SOURCE=local

# Server discovery
DISCOVERY_MDNS=true
DISCOVERY_TAILSCALE=true

# Update checks
UPDATE_CHECK=true

# Feature toggles
MODULE_TERMINAL=true
MODULE_SSH=true
MODULE_AGENT=true
MODULE_RAG=true
MODULE_EMAIL=true
MODULE_CALENDAR=true
MODULE_NOTES=true
MODULE_TASKS=true
MODULE_RESEARCH=true
MODULE_DOCUMENTS=true
MODULE_COOKBOOK=true
MODULE_CONNECTIONS=true
